{
  "info": {
    "name": "GitHub Analyzer API",
    "description": "Collection for testing GitHub Profile Analyzer API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Check API and database health status"
      }
    },
    {
      "name": "Analyze Profile",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"octocat\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/profiles/analyze",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "profiles", "analyze"]
        },
        "description": "Fetch GitHub profile, analyze, and store in database"
      }
    },
    {
      "name": "Get All Profiles",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/profiles?page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "profiles"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        },
        "description": "Get all analyzed profiles with pagination"
      }
    },
    {
      "name": "Get Single Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/profiles/octocat",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "profiles", "octocat"]
        },
        "description": "Get a specific profile by username"
      }
    },
    {
      "name": "Refresh Profile",
      "request": {
        "method": "PUT",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/profiles/octocat/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "profiles", "octocat", "refresh"]
        },
        "description": "Re-fetch profile data from GitHub and update database"
      }
    },
    {
      "name": "Delete Profile",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/profiles/octocat",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "profiles", "octocat"]
        },
        "description": "Delete a profile from the database"
      }
    }
  ]
}
